# ═══════════════════════════════════════════════════════════════
# Effy v3.5 — .gitignore
# ═══════════════════════════════════════════════════════════════

# ─── Environment & Secrets ───
.env
.env.*
!.env.example

# ─── Dependencies ───
node_modules/
# NOTE: package-lock.json은 반드시 커밋 (npm ci 재현성 보장)

# ─── Data / Runtime ───
data/
*.db
*.db-wal
*.db-shm
*.ndjson

# ─── Build / Output ───
dist/
build/
coverage/
*.tgz

# ─── Logs ───
logs/
*.log
npm-debug.log*

# ─── IDE / Editor ───
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ─── OS ───
.DS_Store
Thumbs.db

# ─── Docker ───
docker-compose.override.yml

# ─── Legacy (removed in v3.5) ───
src-legacy/
_legacy/
__pycache__/
*.pyc
.venv/
venv/
requirements.txt
main.py
