# Effy v3.9 Environment Variables
# Copy this file to .env and fill in the values for your deployment

# Core Configuration
# Path to the YAML configuration file (required)
EFFY_CONFIG=./effy.config.yaml

# Node environment (development, staging, production)
NODE_ENV=development

# API Keys and Credentials
# Anthropic API key for Claude models (required)
ANTHROPIC_API_KEY=sk-ant-...

# Slack integration
# Slack bot token (required)
SLACK_BOT_TOKEN=xoxb-...

# Slack app token (required)
SLACK_APP_TOKEN=xapp-...

# Search functionality
# Search engine type (e.g., 'google', 'elasticsearch')
SEARCH_ENGINE=google

# API key for search service
SEARCH_API_KEY=

# OpenAI (optional, for legacy integrations)
OPENAI_API_KEY=sk-...

# Database Configuration
# Database type: sqlite, postgres, or postgresql (phase 1 = sqlite, phase 2 = postgres)
DB_TYPE=sqlite

# PostgreSQL connection URL (used when DB_TYPE=postgres)
DATABASE_URL=postgres://user:password@localhost:5432/effy

# PostgreSQL host (fallback for url construction)
DB_HOST=localhost

# PostgreSQL port
DB_PORT=5432

# PostgreSQL database name
DB_NAME=effy

# PostgreSQL username
DB_USER=effy

# PostgreSQL password
DB_PASSWORD=

# PostgreSQL SSL connection (true/false)
DB_SSL=false

# Logging
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Slack Alerting (optional)
# Channel ID for alert messages
SLACK_ALERT_CHANNEL=

# Knowledge Base Integration (optional)
# Directory path for CHUB knowledge base
CHUB_DIR=./knowledge

# URL for CHUB bundle downloads
CHUB_BUNDLE_URL=

# Application Version
VERSION=3.9.0
