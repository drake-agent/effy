# ──────────────────────────────────────────────────────────
# Effy v4.0 — Environment Variables
# Copy to .env and fill in required values.
# ──────────────────────────────────────────────────────────

# ─── Required ────────────────────────────────────────────
# Anthropic API key (REQUIRED)
ANTHROPIC_API_KEY=sk-ant-...

# Slack Bot Token (REQUIRED if Slack channel enabled)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ─── Config ──────────────────────────────────────────────
# Path to effy.config.yaml (default: ./effy.config.yaml)
# EFFY_CONFIG=./effy.config.yaml

# Node environment (development | production | test)
# NODE_ENV=development

# Log level (debug | info | warn | error)
# LOG_LEVEL=info

# ─── Gateway v2 (Strangler Fig) ─────────────────────────
# Enable pipeline-based gateway (default: false)
# EFFY_GATEWAY_V2=false

# ─── Database ────────────────────────────────────────────
# PostgreSQL connection (Phase 2 — omit for SQLite Phase 1)
# DATABASE_URL=postgresql://user:pass@localhost:5432/effy

# Individual PG params (alternative to DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=effy
# DB_USER=effy
# DB_PASSWORD=
# DB_SSL=false

# ─── Redis Cache (optional — for horizontal scaling) ────
# Redis connection URL (preferred)
# REDIS_URL=redis://:password@localhost:6379/0

# Individual Redis params (alternative to REDIS_URL)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── LLM Fallback ───────────────────────────────────────
# OpenAI fallback API key (optional)
# OPENAI_API_KEY=sk-...

# ─── Search ──────────────────────────────────────────────
# Web search API key (Brave/SerpAPI — for web_search tool)
# SEARCH_API_KEY=
# SEARCH_ENGINE=brave

# ─── Microsoft Teams (optional) ─────────────────────────
# TEAMS_TENANT_ID=
# TEAMS_APP_ID=
# TEAMS_APP_PASSWORD=
# BASE_PATH=

# ─── Slack Alerts ────────────────────────────────────────
# Channel for incident alerts (optional)
# SLACK_ALERT_CHANNEL=C...

# ─── Summarization ──────────────────────────────────────
# Concurrent summarization workers (default: 2)
# EFFY_SUMMARIZATION_CONCURRENCY=2

# ─── Context Hub (optional) ─────────────────────────────
# CHUB_DIR=~/.chub
# CHUB_BUNDLE_URL=

# ─── A2A Protocol (optional — Agent-to-Agent) ───────────
# A2A_ENABLED=true
# A2A_PUBLIC_URL=https://your-effy-instance.example.com
# A2A_API_KEY=your-a2a-api-key
# A2A_API_KEY_2=optional-second-key

# ─── Secrets ────────────────────────────────────────────
# JWT secret for token signing (required for auth endpoints)
# JWT_SECRET=

# Internal secret for inter-service authentication
# EFFY_INTERNAL_SECRET=

# ─── GitHub Integration (optional) ─────────────────────
# Webhook secret for verifying GitHub webhook payloads
# GITHUB_WEBHOOK_SECRET=

# ─── Health Check ──────────────────────────────────────
# Port for health check endpoint (default: 9090)
# HEALTH_PORT=9090

# ─── Vault ─────────────────────────────────────────────
# Master key for secret encryption (required for vault)
# VAULT_MASTER_KEY=

# ─── Observability (optional) ───────────────────────────
# VERSION=4.0.0
